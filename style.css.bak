/* ========================= */
/* CONFIGURAÇÃO GERAL DO SITE */
/* ========================= */

html {
  scroll-behavior: smooth;
  scroll-padding-top: 90px;
}

body{
font-family: Arial, sans-serif; 
/* Define a fonte principal do site */

margin:0;
/* Remove margens externas do navegador */

padding:0;
/* Remove espaçamento interno padrão */

background:white;
/* Define fundo branco para o site */
}


/* ========================= */
/* LOGO DA NAVBAR */
/* ========================= */

.logo{
height:45px;
/* Define altura da logo para manter navbar elegante */
}


/* ========================= */
/* HERO SECTION (PRIMEIRA PARTE DO SITE) */
/* ========================= */

.hero{
padding-top:120px;
/* Espaço acima da seção (evita ficar escondida atrás da navbar) */

padding-bottom:100px;
/* Espaço abaixo da seção */

background:#f8f8f8;
/* Cor de fundo cinza bem claro */
}


/* Título principal da hero */

.titulo{
font-size:42px;
/* Define tamanho grande do título */

font-weight:600;
/* Deixa o texto semi-negrito */

margin-bottom:20px;
/* Espaço abaixo do título */
}


/* Subtítulo da hero */

.subtitulo{
font-size:18px;
/* Define tamanho do texto */

color:#555;
/* Define cor cinza para texto */

margin-bottom:40px;
/* Espaço abaixo do texto */
}


/* ========================= */
/* BOTÕES DO SITE */
/* ========================= */

.btn{
transition:0.3s;
/* Cria transição suave ao passar o mouse */
}

.btn:hover{
transform:scale(1.05);
/* Ao passar o mouse o botão aumenta levemente */
}


/* ========================= */
/* SEÇÃO DE SERVIÇOS */
/* ========================= */

.servicos{
padding:80px 0;
/* Espaço vertical acima e abaixo da seção */
}


/* Card que representa cada serviço */

.card-servico{

padding:30px;
/* Espaço interno do card */

border:1px solid #eee;
/* Borda cinza bem clara */

transition:0.3s;
/* Animação suave */
}


/* Efeito hover ao passar o mouse */

.card-servico:hover{

transform:translateY(-5px);
/* Card sobe levemente */

box-shadow:0 10px 25px rgba(0,0,0,0.1);
/* Cria sombra suave */
}


/* ========================= */
/* CHAMADA DO CASTING */
/* ========================= */

.casting-call{
  padding:80px 0;
  background-color:#f4f4f4;
  background-image:
    radial-gradient(circle at 2% 5%, rgba(219,179,156,0.2) 0%, rgba(219,179,156,0.2) 10%, transparent 10.5%),
    radial-gradient(circle at 70% 15%, rgba(150, 89, 47,0.12) 0%, rgba(150, 89, 47,0.12) 8%, transparent 8.5%),
    repeating-radial-gradient(circle at 20% 80%, rgba(219,179,156,0.1), rgba(219,179,156,0.1) 10px, transparent 10px, transparent 20px);
  background-blend-mode: normal, normal, overlay;
}

.casting-pattern {
  background-color:#fff;
  background-image:
    radial-gradient(circle at 20% 20%, #fff 0, #fff 20%, #d6a777 20%, #d6a777 30%, #fff 30%, #fff 40%, #795548 40%, #795548 45%, #fff 45%, #fff 100%),
    linear-gradient(45deg, rgba(219,179,156,0.2) 25%, transparent 25%, transparent 75%, rgba(219,179,156,0.2) 75%, rgba(219,179,156,0.2)),
    linear-gradient(-45deg, rgba(219,179,156,0.2) 25%, transparent 25%, transparent 75%, rgba(219,179,156,0.2) 75%, rgba(219,179,156,0.2));
  background-size: 80px 80px, 40px 40px, 40px 40px;
  border-radius: 18px;
  min-height: 380px;
}

.casting-call h1{font-size:2.3rem;color:#1f1f1f;}
.casting-call p{color:#333;}


/* ========================= */
/* SEÇÃO DO BLOG */
/* ========================= */

.blog{

padding:80px 0;
/* Espaço acima e abaixo da seção */
}


/* Card de postagem do blog */

.card-blog{

padding:20px;
/* Espaçamento interno */

border:1px solid #eee;
/* Borda leve */
}


/* ========================= */
/* FOOTER (RODAPÉ) */
/* ========================= */

footer{

background:#000;
/* Fundo preto */

color:white;
/* Texto branco */

padding:30px 0;
/* Espaçamento interno */

margin-top:50px;
/* Espaço acima do rodapé */
}


/* ========================= */
/* ANIMAÇÃO DA NAVBAR */
/* ========================= */

.navbar-hidden{

transform:translateY(-100%);
/* Move a navbar para fora da tela */

transition:0.3s;
/* Transição suave */
}

/* ======================================== */
/* ESTILO DOS ICONES DA PAGINA DE CONTATO */
/* ======================================== */

/* ================================= */
/* COR PERSONALIZADA DOS ICONES */
/* ================================= */

/* força a cor dos ícones */

/* ================================= */
/* COR DOS ICONES DA PAGINA CONTATO */
/* ================================= */

/* ================================= */
/* ESTILO DA PAGINA DE CONTATO */
/* ================================= */

/* Ajusta espaço da seção */
#contato{
padding-top:60px;
padding-bottom:60px;
}

/* Remove cor azul padrão dos links do Bootstrap */
#contato a{
text-decoration:none;
color:inherit;
}

/* Estilo dos ícones */
#contato i,
#contato a i {
  color:#DBB39C !important; /* cor da identidade visual */
  font-size:50px; /* aumenta tamanho do ícone */
  transition:0.3s; /* animação suave */
}

/* Efeito quando passa o mouse */
#contato a:hover i{
  color:#c79a82 !important; /* cor um pouco mais escura */
  transform:scale(1.2); /* aumenta o ícone */
}

/* Estilo do título (WhatsApp, Instagram, Email) */
#contato h5{

margin-top:15px;

font-weight:600;

}

/* Estilo do texto abaixo */
#contato p{

color:#555;

font-size:15px;

}
/* ============================= */
/* TAMANHO DA LOGO DO NAVBAR */
/* ============================= */

   /* mantém proporção da imagem */

/* ================================ */
/* SEÇÃO SOBRE YBYRA CASTING */
/* ================================ */

#sobre{

width:100%;

min-height:100vh;

display:flex;

align-items:center;

background:#f8f8f8;

}

/* coluna da imagem */

.sobre-imagem{

background-image:url("Ybyra.lab.jpeg");

background-size:cover;

background-position:center;

min-height:600px;

transition:0.6s;

}

/* efeito leve na imagem */

.sobre-imagem:hover{

transform:scale(1.03);

filter:brightness(90%);

}

/* coluna texto */

.sobre-texto{

padding:80px;

display:flex;

flex-direction:column;

justify-content:center;

animation:fadeEntrada 1.2s ease;

}

/* titulo */

.sobre-texto h2{

font-size:38px;

margin-bottom:25px;

font-weight:700;

color:#222;

}

/* paragrafos */

.sobre-texto p{

font-size:18px;

line-height:1.7;

color:#555;

margin-bottom:20px;

}

/* botão */

.btn-sobre{

display:inline-block;

margin-top:20px;

padding:14px 28px;

background:#DBB39C;

color:white;

text-decoration:none;

border-radius:6px;

font-weight:600;

transition:0.3s;

}

/* efeito hover */

.btn-sobre:hover{

background:#c79a82;

transform:translateY(-3px);

box-shadow:0 8px 20px rgba(0,0,0,0.15);

}

/* animação de entrada */

@keyframes fadeEntrada{

from{

opacity:0;

transform:translateX(40px);

}

to{

opacity:1;

transform:translateX(0);

}

}

/* ================= HERO SECTION ================= */

#hero{

height:100vh;

background-image:url("Ybyra.lab.jpeg");

background-size:cover;

background-position:center;

position:relative;

display:flex;

align-items:center;

justify-content:center;

text-align:center;

color:white;

}

/* camada escura para destacar o texto */

.overlay{

position:absolute;

top:0;

left:0;

width:100%;

height:100%;

background:rgba(0,0,0,0.45);

}

/* conteúdo central */

.hero-conteudo{

position:relative;

z-index:2;

animation:fadeHero 1.5s ease;

}

/* título */

.hero-conteudo h1{

font-size:70px;

font-weight:700;

letter-spacing:3px;

margin-bottom:20px;

}

/* texto */

.hero-conteudo p{

font-size:22px;

margin-bottom:30px;

}

/* botão */

.btn-hero{

padding:15px 35px;

background:#DBB39C;

color:white;

text-decoration:none;

font-size:18px;

border-radius:6px;

transition:0.3s;

}

/* hover botão */

.btn-hero:hover{

background:#c79a82;

transform:translateY(-3px);

box-shadow:0 10px 25px rgba(0,0,0,0.3);

}

/* animação */

@keyframes fadeHero{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}