<!DOCTYPE html>
<html lang="pt-br">

<head>

<meta charset="UTF-8">
<!-- Permite usar acentos -->

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<!-- Faz o site ser responsivo -->

<title>Ybyra Casting</title>
<!-- Título da aba do navegador -->

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Importa o framework Bootstrap -->

<!-- CSS do projeto -->
<link rel="stylesheet" href="css/style.css">
<!-- Arquivo de estilos personalizado -->

</head>

<body>

<!-- ================= NAVBAR ================= -->

<nav id="navbar" class="navbar navbar-expand-lg fixed-top bg-white shadow-sm">
<!-- Navbar fixa no topo -->

<div class="container">

<a class="navbar-brand" href="index.html">
<!-- Link da logo para home -->

<img src="" class="logo-navbar">
<!-- Logo da empresa -->

</a>

<button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
<!-- Botão do menu mobile -->

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse justify-content-end" id="menu">
<!-- Menu alinhado à direita -->

<ul class="navbar-nav">

<li class="nav-item">
<a class="nav-link" href="#hero">Home</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#servicos">Serviços</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#sobre">Sobre</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#contato">Contato</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#blog">Blog</a>
</li>

</ul>

</div>

</div>

</nav>


<!-- ================= HERO ================= -->

<section id="hero" class="hero">

<div class="container text-center">

<h1 class="titulo">
Curadoria e desenvolvimento de talentos para o setor cultural e audiovisual
</h1>

<p class="subtitulo">
A Ybyra Casting conecta talentos, produtores e marcas através de um processo profissional de curadoria cultural.
</p>

<div class="mt-4">

<a href="contato.html" class="btn btn-dark btn-lg btn-produtor">
Solicitar Elenco
</a>

<a href="cadastro.html" class="btn btn-outline-dark btn-lg btn-casting">
Inscreva-se no Casting
</a>

</div>

</div>

</section>


<!-- ================= SERVIÇOS ================= -->

<section id="servicos" class="servicos">

<div class="container">

<h2 class="text-center mb-5">O que fazemos</h2>

<div class="row">

<div class="col-md-4">

<div class="card-servico">

<h3>Casting</h3>

<p>
Curadoria de talentos para produções culturais e audiovisuais.
</p>

</div>

</div>

<div class="col-md-4">

<div class="card-servico">

<h3>Produção Cultural</h3>

<p>
Desenvolvimento e gestão de projetos culturais e artísticos.
</p>

</div>

</div>

<div class="col-md-4">

<div class="card-servico">

<h3>Formação</h3>

<p>
Workshops e programas de desenvolvimento para novos talentos.
</p>

</div>

</div>

</div>

</div>

</section>


<!-- ================= CHAMADA CASTING ================= -->

<section id="casting" class="casting-call">

<div class="container text-center">

<h2>Faça parte do banco de talentos</h2>

<p>
Modelos, atores e artistas podem se inscrever no banco de talentos da Ybyra Casting.
</p>

<a href="cadastro.html" class="btn btn-dark btn-lg btn-casting">
Cadastrar no Casting
</a>

</div>

</section>


<!-- ================= SOBRE ================= -->

<section id="sobre" class="sobre">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-6 sobre-texto">
        <h2>Sobre a Ybyra Casting</h2>
        <p>Somos uma agência de curadoria e desenvolvimento de talentos para o setor cultural e audiovisual. Ajudamos produtores a encontrar o elenco certo e talentos a crescerem com projetos profissionais.</p>
        <a class="btn-sobre" href="#contato">Fale Conosco</a>
      </div>
      <div class="col-md-6 sobra"><div class="sobre-imagem"></div></div>
    </div>
  </div>
</section>


<!-- ================= CONTATO ================= -->

<section id="contato" class="contato py-5">
  <div class="container">
    <div class="row">
      <div class="col-md-6">
        <h2>Contato</h2>
        <p>Tem um projeto? Fale com a gente e vamos conectar o melhor elenco para a sua produção.</p>
        <p><strong>Email:</strong> contato@ybyra.com</p>
        <p><strong>Telefone:</strong> +55 11 99999-9999</p>
      </div>
      <div class="col-md-6">
        <h5>Nossas redes</h5>
        <p>Instagram: @ybyracasting</p>
        <p>WhatsApp: (11) 99999-9999</p>
      </div>
    </div>
  </div>
</section>


<!-- ================= BLOG ================= -->

<section id="blog" class="blog">

<div class="container">

<h2 class="text-center mb-5">Notícias e Atualizações</h2>

<div class="row">

<div class="col-md-4">

<div class="card-blog">

<h4>
Filme premiado no Oscar movimenta o cenário cultural
</h4>

<p>
Análise do impacto das premiações internacionais no mercado cultural e audiovisual.
</p>

</div>

</div>

</div>

</div>

</section>


<!-- ================= FOOTER ================= -->

<footer>

<div class="container text-center">

<p>
Ybyra Casting — Curadoria, formação e produção cultural de talentos.
</p>

</div>

</footer>


<!-- ================= SCRIPT DE MÉTRICAS ================= -->

<script>

/*
Este script envia informações para a API de métricas
sempre que alguém acessa uma página do site
*/

fetch("https://api.ybyra.com/metrics",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({

pagina:window.location.pathname,
/* envia qual página foi acessada */

data:new Date(),
/* envia data e hora do acesso */

navegador:navigator.userAgent
/* envia navegador utilizado */

})

})

</script>


<!-- ================= EVENTO CLIQUE CASTING ================= -->

<script>

/*
Este evento registra quando alguém clica
no botão de inscrição no casting
*/

document.querySelectorAll(".btn-casting").forEach(function(botao){

botao.addEventListener("click",function(){

fetch("https://api.ybyra.com/metricas/casting")

})

})

</script>


<!-- ================= EVENTO CLIQUE PRODUTOR ================= -->

<script>

/*
Este evento registra quando um produtor
clica para solicitar elenco
*/

document.querySelectorAll(".btn-produtor").forEach(function(botao){

botao.addEventListener("click",function(){

fetch("https://api.ybyra.com/metricas/produtor")

})

})

</script>


<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- JS do projeto -->
<script src="js/script.js"></script>


</body>
</html>